// Aperture Prisma schema — starting fresh, feature by feature
// Feature #1: Authentication (User model only)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())

  photos Photo[]
}

model Photo {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  authorId    String
  createdAt   DateTime @default(now())

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags   TaggedPhoto[]
}

model Tag {
  id     String        @id @default(cuid())
  name   String        @unique
  photos TaggedPhoto[]
}

model TaggedPhoto {
  id      String @id @default(cuid())
  photoId String
  tagId   String

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([photoId, tagId])
}

