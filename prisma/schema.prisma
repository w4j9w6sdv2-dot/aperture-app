// Aperture Prisma schema — starting fresh, feature by feature
// Feature #1: Authentication (User model only)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
}
