// Aperture Prisma schema — starting fresh, feature by feature
// Feature #1: Authentication (User model only)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  username         String   @unique
  email            String   @unique
  passwordHash     String
  bio              String?
  avatarUrl        String?
  isAdult          Boolean  @default(false)
  showAdultContent Boolean  @default(false)
  createdAt        DateTime @default(now())

  photos   Photo[]
  comments Comment[]
  likes    Like[]
  collections Collection[]
}

model Photo {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  authorId    String
  isAdult     Boolean  @default(false)
  categoryId  String?
  createdAt   DateTime @default(now())

  author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags     TaggedPhoto[]
  comments Comment[]
  likes    Like[]
  category Category?      @relation(fields: [categoryId], references: [id])
  savedIn  SavedPhoto[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  isAdult   Boolean  @default(false)
  createdAt DateTime @default(now())

  photos Photo[]
}

model Tag {
  id     String        @id @default(cuid())
  name   String        @unique
  photos TaggedPhoto[]
}

model TaggedPhoto {
  id      String @id @default(cuid())
  photoId String
  tagId   String

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([photoId, tagId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  authorId  String
  photoId   String
  createdAt DateTime @default(now())

  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  photo  Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
}

model Like {
  id      String @id @default(cuid())
  userId  String
  photoId String

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([userId, photoId])
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner  User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  photos SavedPhoto[]
}

model SavedPhoto {
  id           String     @id @default(cuid())
  collectionId String
  photoId      String
  addedAt      DateTime   @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  photo      Photo       @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([collectionId, photoId])
}

